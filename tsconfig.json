{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "src/index.ts",
    "src/config/constants.ts",
    "src/config/env.ts",
    "src/server/**/*.ts",
    "src/rpc/**/*.ts",
    "src/cdp/**/*.ts",
    "src/events/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
