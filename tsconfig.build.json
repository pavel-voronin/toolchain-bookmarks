{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": [
    "src/index.ts",
    "src/config/constants.ts",
    "src/config/env.ts",
    "src/server/**/*.ts",
    "src/rpc/**/*.ts",
    "src/cdp/**/*.ts",
    "src/events/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "tests"]
}
